@model IEnumerable<Ecommerce_DBFirst.ViewModels.InventoryItemVM>

@{
    ViewData["Title"] = "Inventory";
}

<h2>Inventory</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Add Inventory Record</a>
    </p>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Product ID</th>
            <th>Product</th>
            <th>Stock Quantity</th>
            <th>Availability</th>
            <th>Last Updated (UTC)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ProductId</td>
                <td>@item.ProductName</td>
                <td>@item.StockQuantity</td>
                <td>
                    @if (item.StockQuantity > 0)
                    {
                        <span class="badge bg-success">In Stock</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Out of Stock</span>
                    }
                </td>
                <td>@item.LastUpdated</td>
                <td>
                    <a asp-action="Details" asp-route-productId="@item.ProductId" class="btn btn-sm btn-info">Details</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="UpdateStock" asp-route-productId="@item.ProductId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-productId="@item.ProductId" class="btn btn-sm btn-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
