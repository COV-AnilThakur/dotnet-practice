@model IEnumerable<Ecommerce_DBFirst.Models.Category>

@{
    ViewData["Title"] = "Categories"; // Using ViewData as required
}

<h1>@ViewData["Title"]</h1>

@* Mandatory TempData display for Assignment 4 *@
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

@if (User.IsInRole("Admin"))
{
    <p><a asp-action="Create" class="btn btn-primary">Add New Category</a></p>
}

<table class="table">
    <thead>
        <tr>
            <th>Category Name</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CategoryName</td>
                <td>
                    <a href="/categories/@item.CategoryId/products" class="btn btn-sm btn-info">View Products</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-sm btn-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
